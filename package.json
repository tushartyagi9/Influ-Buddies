{
  "name": "checkers-1",
  "version": "1.0.0",
  "description": "Influ-Buddies MERN monorepo (client + server)",
  "main": "index.js",
  "scripts": {
    "dev": "npm-run-all --parallel dev:server dev:client",
    "dev:server": "npm run dev --prefix server",
    "dev:client": "npm run dev --prefix client",
    "build": "npm run build --prefix client",
    "start": "npm run start --prefix server",
    "render-build": "cd client && npm install && npm run build && cd ../server && npm install"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tushart99/checkers.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "npm-run-all": "^4.1.5"
  }
}
